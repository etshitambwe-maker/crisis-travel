# ============================================================
# CRISIS TRAVEL — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS committer .env.local
# ============================================================

# ── CRITIQUE (sans ces variables, l'app ne fonctionne pas) ──

# Anthropic Claude API
# Inscription : https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (PostgreSQL + Auth)
# Inscription : https://supabase.com → Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Upstash Redis (cache + rate limiting)
# Inscription : https://upstash.com → Console > Redis > REST API
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ── MONÉTISATION (Stripe) ────────────────────────────────────

# Créer les produits dans Stripe Dashboard avant de remplir
# Dashboard : https://dashboard.stripe.com/products
STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY : non utilisée par le runtime actuel
# (le checkout se fait côté serveur). Réservée à un usage Stripe.js client futur.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook : Stripe Dashboard > Developers > Webhooks
# URL : https://votre-domaine.vercel.app/api/stripe/webhook
# Événements requis : customer.subscription.created/updated/deleted, checkout.session.completed, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs des prix Stripe (récupérés dans Stripe Dashboard après création)
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_ANNUAL=price_...

# ── GÉOPOLITIQUE (haute priorité) ───────────────────────────

# Perplexity via OpenRouter (analyse géopolitique temps réel)
# Inscription : https://openrouter.ai → API Keys
OPENROUTER_API_KEY=sk-or-...

# ACLED (conflits armés géolocalisés)
# Inscription gratuite : https://developer.acleddata.com (délai 24-48h)
# ACLED_EMAIL : requis à l'inscription ACLED mais non lu par le runtime
# (seul ACLED_ACCESS_KEY est utilisé par lib/services/security/acled.service.ts).
ACLED_EMAIL=votre@email.com
ACLED_ACCESS_KEY=...

# ── EMAILS (alertes pays) ───────────────────────────────────

# Resend (envoi emails alertes pays)
# Inscription : https://resend.com → ajouter domaine crisis-travel.app
RESEND_API_KEY=re_...

# ── CRON (sécurité) ─────────────────────────────────────────

# Token secret pour sécuriser le cron job Vercel
# Générer avec : openssl rand -hex 32
CRON_SECRET=changez_ce_secret_en_production

# ── OPTIONNEL ────────────────────────────────────────────────

# Numbeo API (coût de vie précis par ville/pays)
# Inscription : https://www.numbeo.com/api/
NUMBEO_API_KEY=

# URL publique de l'application (obligatoire en production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Amadeus (vols temps réel — Phase 2)
# Réservé futur / NON utilisé actuellement : les prix de vol affichés sont des
# estimations statiques (components/crisis/TravelPackBlock.tsx), pas des appels Amadeus.
# Inscription : https://developers.amadeus.com
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_ENV=test

# ── APIS GRATUITES (aucune configuration requise) ────────────
# Ces APIs fonctionnent sans clé :
# - Frankfurter (taux de change) : https://api.frankfurter.app
# - World Bank : https://api.worldbank.org
# - GDELT : https://api.gdeltproject.org
# - France Diplomatie MEAE : https://www.diplomatie.gouv.fr
# - UK FCDO : https://www.gov.uk/foreign-travel-advice
# - US State Department : https://travel.state.gov
# - NASA EONET (catastrophes) : https://eonet.gsfc.nasa.gov
# - Teleport (qualité de vie) : https://api.teleport.org
# - ReliefWeb/OCHA (crises humanitaires) : https://api.reliefweb.int
